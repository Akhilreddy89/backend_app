<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
</head>
<body>
    <h1>Edit Product</h1>
    <form action="/products/<%= product._id %>/save" method="POST">
        <p><input type="text" name="name" placeholder="Product Name" value="<%= product.name %>"></p>
        <p><input type="number" name="price" placeholder="Price" value="<%= product.price %>"></p>
        <p><input type="text" name="desc" placeholder="Description" value="<%= product.desc %>"></p>
        <p><input type="text" name="imageurl" placeholder="Image URL" value="<%= product.imageurl %>"></p>
        <p><input type="submit" value="Update Product"></p>
    </form>
</body>
</html>